# Token Monitor — environment configuration.
# Copy to .env (gitignored) and fill in. Only needed for the hub and the
# headless agent; the widget can also read these as first-run defaults
# before its GUI settings take over.

# Hub URL — required for the agent and for any widget in sync mode.
TOKEN_MONITOR_HUB_URL=http://127.0.0.1:17321

# Shared secret — must match on the hub, agent, and any widget that syncs.
# Leave empty to run the hub without authentication (not recommended).
TOKEN_MONITOR_SECRET=change-me

# Device identifier. Optional — defaults to the machine hostname.
TOKEN_MONITOR_DEVICE_ID=

# Comma-separated client list. Optional — defaults to all supported tools.
# Example: claude,codex,hermes,opencode,openclaw,cursor
TOKEN_MONITOR_CLIENTS=
